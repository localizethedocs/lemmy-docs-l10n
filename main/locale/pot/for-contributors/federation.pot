msgstr ""

#: src/contributors/05-federation.md:25 src/contributors/05-federation.md:987
msgid "\"https://www.w3.org/ns/activitystreams\""
msgstr ""

#: src/contributors/05-federation.md:29
msgid "The context is identical for all activities and objects."
msgstr ""

#: src/contributors/05-federation.md:31
msgid "Actors"
msgstr ""

#: src/contributors/05-federation.md:33
msgid "Community"
msgstr ""

#: src/contributors/05-federation.md:35
msgid ""
"An automated actor. Users can send posts or comments to it, which the "
"community forwards to its followers in the form of `Announce`."
msgstr ""

