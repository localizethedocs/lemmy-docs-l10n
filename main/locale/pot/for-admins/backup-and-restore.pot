#: src/administration/backup_and_restore.md:1
msgid "Backup and Restore"
msgstr ""

#: src/administration/backup_and_restore.md:3
msgid "Docker and Ansible"
msgstr ""

#: src/administration/backup_and_restore.md:5
msgid ""
"When using docker or ansible, there should be a `volumes` folder, which "
"contains both the database, and all the pictures. Copy this folder to the "
"new instance to restore your data."
msgstr ""

#: src/administration/backup_and_restore.md:7
msgid "Full Database backup"
msgstr ""

#: src/administration/backup_and_restore.md:9
msgid "To take a complete backup of the DB to a `.sql.gz` file, you can run:"
msgstr ""

#: src/administration/backup_and_restore.md:12
#: src/administration/backup_and_restore.md:22
msgid "\"_\""
msgstr ""

#: src/administration/backup_and_restore.md:15
msgid "_For compression, you can use either gzip and gunzip, or xz and unxz._"
msgstr ""

#: src/administration/backup_and_restore.md:17
msgid "A Sample backup script"
msgstr ""

#: src/administration/backup_and_restore.md:20
msgid ""
"#!/bin/sh\n"
"# DB Backup\n"
msgstr ""

#: src/administration/backup_and_restore.md:22
msgid "\"docker compose exec postgres pg_dumpall -c -U lemmy\""
msgstr ""

#: src/administration/backup_and_restore.md:23
msgid "# Volumes folder Backup\n"
msgstr ""

#: src/administration/backup_and_restore.md:25
msgid "\"sudo rsync\""
msgstr ""

#: src/administration/backup_and_restore.md:28
msgid "Restoring the DB"
msgstr ""

#: src/administration/backup_and_restore.md:30
msgid "To restore, run:"
msgstr ""

#: src/administration/backup_and_restore.md:34
msgid "# Restore from the .sql.gz backup\n"
msgstr ""

#: src/administration/backup_and_restore.md:37
msgid ""
"# Note: You may need to change the permissions on the postgres directory, "
"depending on your system.\n"
msgstr ""

#: src/administration/backup_and_restore.md:41
msgid "# Continue with the startup\n"
msgstr ""

#: src/administration/backup_and_restore.md:46
msgid ""
"If you've accidentally already started the lemmy service, you need to clear "
"out your existing database:"
msgstr ""

#: src/administration/backup_and_restore.md:49
msgid "# Drop the existing DB\n"
msgstr ""

#: src/administration/backup_and_restore.md:50
msgid "\"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\""
msgstr ""

#: src/administration/backup_and_restore.md:51
msgid ""
"# This also might be necessary when doing a db import with a different "
"password.\n"
msgstr ""

#: src/administration/backup_and_restore.md:53
msgid "\"alter user lemmy with password 'bleh'\""
msgstr ""

#: src/administration/backup_and_restore.md:56
msgid "Then run the restore commands above."
msgstr ""

#: src/administration/backup_and_restore.md:58
msgid "Changing your domain name"
msgstr ""

#: src/administration/backup_and_restore.md:60
msgid ""
"If you haven't federated yet, you can change your domain name in the DB. "
"**Warning: do not do this after you've federated, or it will break "
"federation.**"
msgstr ""

#: src/administration/backup_and_restore.md:62
msgid "Get into `psql` for your docker:"
msgstr ""

#: src/administration/backup_and_restore.md:64
msgid "`docker compose exec postgres psql -U lemmy`"
msgstr ""

