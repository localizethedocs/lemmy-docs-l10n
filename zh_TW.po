"[target.x86_64-unknown-linux-gnu]\n"
"linker = \"clang\"\n"
"rustflags = [\"-C\", \"link-arg=-fuse-ld=/usr/bin/mold\", \"-Z\", "
"\"threads=16\"]\n"
"```"
