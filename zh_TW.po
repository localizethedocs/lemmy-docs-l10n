#: src/administration/from_scratch.md:69
msgid "AppImage-based installation of ImageMagick"
msgstr ""

#: src/administration/from_scratch.md:71
msgid ""
"```\n"
"sudo apt install ffmpeg exiftool libgexiv2-dev --no-install-recommends\n"
"# save the file to a working folder it can be verified before copying to /"
"usr/bin/\n"
"wget https://download.imagemagick.org/ImageMagick/download/binaries/magick\n"
"# compare hash with the \"message digest\" on the official page linked "
"above\n"
"sha256sum magick\n"
"sudo mv magick /usr/bin/\n"
"sudo chmod 755 /usr/bin/magick\n"
"```"
