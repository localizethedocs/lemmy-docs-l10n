msgid "job_name"
msgstr ""

#: src/administration/prometheus.md:40 src/administration/prometheus.md:59
msgid "lemmy"
msgstr ""

#: src/administration/prometheus.md:41 src/administration/prometheus.md:60
msgid "scrape_interval"
msgstr ""

#: src/administration/prometheus.md:41 src/administration/prometheus.md:60
msgid "1m"
msgstr ""

#: src/administration/prometheus.md:42 src/administration/prometheus.md:61
msgid "static_configs"
msgstr ""

